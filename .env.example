# saas-utils Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.

# ─── Upstash Redis (required for: cache, rate-limiter, user-service) ───────────
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Encryption (required for: encryption module) ──────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_char_key_here

# ─── Stripe (required for: stripe module) ──────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Optional: Additional API keys resolved by env-resolver ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
