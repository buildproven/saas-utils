{
  "name": "saas-utils",
  "version": "0.1.0",
  "description": "Production-grade SaaS utility modules: rate limiting, encryption, caching, Stripe, auth, and more",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "saas",
    "utilities",
    "rate-limiter",
    "encryption",
    "stripe",
    "cache",
    "nextjs"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    },
    "./rate-limiter": {
      "types": "./dist/rate-limiter/index.d.ts",
      "default": "./dist/rate-limiter/index.js"
    },
    "./stripe/testing": {
      "types": "./dist/stripe/testing.d.ts",
      "default": "./dist/stripe/testing.js"
    },
    "./type-guards": {
      "types": "./dist/type-guards/index.d.ts",
      "default": "./dist/type-guards/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint . --config eslint.config.cjs",
    "lint:fix": "eslint . --config eslint.config.cjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "dead-code": "knip --no-exit-code || echo \"Dead code found (non-blocking)\"",
    "dead-code:strict": "knip",
    "pattern-check": "bash scripts/pattern-check.sh",
    "test:patterns": "bash scripts/pattern-check.sh --all",
    "prepare": "husky",
    "security:scan": "bash scripts/run-semgrep.sh",
    "security:scan:ci": "bash scripts/run-semgrep.sh --ci",
    "license:check": "license-checker --onlyAllow \"MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;BlueOak-1.0.0;CC0-1.0;CC-BY-3.0;CC-BY-4.0;Unlicense;Python-2.0;MPL-2.0\" --excludePrivatePackages"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --config eslint.config.cjs --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "next": "^15.0.0",
    "prettier": "^3.8.1",
    "stripe": "^17.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
